{
  "name": "hsm",
  "private": true,
  "workspaces": [
    "backend",
    "frontend"
  ],
  "devDependencies": {
    "concurrently": "^9.2.0"
  },
  "scripts": {
    "dev": "npm run -w frontend dev",
    "dev:all": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "npm run -w backend start:dev",
    "dev:frontend": "npm run -w frontend dev",
    "build": "npm run -w frontend build && npm run -w backend build",
    "lint": "npm run -ws lint",
    "format": "npm run -ws format",
    "test": "npm run -ws test"
  }
}
